DB_HOST=db
DB_PORT=5432
DB_USER=ip_admin
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=ip_identity_provider

POSTGRES_DB=ip_identity_provider
POSTGRES_USER=ip_admin
POSTGRES_PASSWORD=YOUR_DB_PASSWORD

# EMAIL CONFIGURATION
MAIL_USERNAME="noreply"
MAIL_PASSWORD="YOUR_MAIL_PASSWORD"
MAIL_FROM="noreply@example.com"
MAIL_PORT=587
MAIL_SERVER="mail.example.com"


AUTH_PRIVATE_KEY=YOUR_BASE64_ENCODED_PRIVATE_KEY
AUTH_KEY_ID=auth-key-1

INTERNAL_API_KEY=YOUR_INTERNAL_API_KEY

ALLOWED_ORIGINS="http://localhost:3000,http://gateway:8000,http://localhost:5173"

# PII Encryption at Rest — Crypto Layer (Fase 1)
# NOTA: Estes valores são para desenvolvimento local. Em produção usar secrets manager (Vault/KMS).
# Chaves hex-encoded de 32 bytes (256 bits) geradas aleatoriamente.
PII_CURRENT_KEY_VERSION=v1
PII_ENCRYPTION_KEY_V1=YOUR_32_BYTE_HEX_ENCRYPTION_KEY
PII_INDEX_KEY_V1=YOUR_32_BYTE_HEX_INDEX_KEY
